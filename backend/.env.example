# Copy to .env and fill in values

# JWT secret — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Users stored as JSON (plain passwords — datathon demo only)
RIGHTAID_USERS_JSON=[{"email":"guest@rightaid.id","password":"guest123","name":"Guest Analyst","role":"guest"},{"email":"analis@kemensos.go.id","password":"kemensos2025","name":"Analis Kemensos","role":"analyst"}]

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

